{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Muvon/octofs",
  "title": "Octofs",
  "description": "Standalone MCP filesystem tools server — view, edit, shell, workdir.",
  "version": "0.4.3",
  "websiteUrl": "https://github.com/muvon/octofs",
  "repository": {
    "url": "https://github.com/muvon/octofs",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "cargo",
      "registryBaseUrl": "https://crates.io",
      "identifier": "octofs",
      "version": "0.4.3",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ]
}
